{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "text-rs",
  "version": "0.2.0",
  "identifier": "com.textrs.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "text-rs",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "center": true,
        "visible": true,
        "focus": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; img-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright 2026 text-rs",
    "category": "DeveloperTool",
    "shortDescription": "A fast, lightweight text editor",
    "longDescription": "text-rs is a cross-platform text editor built with Tauri, Svelte 5, and CodeMirror 6. Fast as Notepad, powerful for developers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Plain Text",
        "ext": ["txt", "log", "csv", "tsv", "ini", "cfg", "conf", "env", "rst"],
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "name": "Markdown",
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "name": "Rust Source",
        "ext": ["rs", "toml"],
        "mimeType": "text/x-rust",
        "role": "Editor"
      },
      {
        "name": "TypeScript Source",
        "ext": ["ts", "tsx"],
        "mimeType": "text/typescript",
        "role": "Editor"
      },
      {
        "name": "JavaScript Source",
        "ext": ["js", "jsx", "mjs", "cjs"],
        "mimeType": "text/javascript",
        "role": "Editor"
      },
      {
        "name": "Python Source",
        "ext": ["py", "pyw"],
        "mimeType": "text/x-python",
        "role": "Editor"
      },
      {
        "name": "HTML",
        "ext": ["html", "htm", "svelte", "vue"],
        "mimeType": "text/html",
        "role": "Editor"
      },
      {
        "name": "CSS",
        "ext": ["css", "scss", "less"],
        "mimeType": "text/css",
        "role": "Editor"
      },
      {
        "name": "JSON",
        "ext": ["json", "jsonc"],
        "mimeType": "application/json",
        "role": "Editor"
      },
      {
        "name": "YAML",
        "ext": ["yaml", "yml"],
        "mimeType": "text/yaml",
        "role": "Editor"
      },
      {
        "name": "XML",
        "ext": ["xml", "svg"],
        "mimeType": "text/xml",
        "role": "Editor"
      },
      {
        "name": "SQL",
        "ext": ["sql", "graphql"],
        "mimeType": "text/x-sql",
        "role": "Editor"
      },
      {
        "name": "Shell Script",
        "ext": ["sh", "bash", "zsh", "fish"],
        "mimeType": "text/x-shellscript",
        "role": "Editor"
      },
      {
        "name": "Go Source",
        "ext": ["go"],
        "mimeType": "text/x-go",
        "role": "Editor"
      },
      {
        "name": "Ruby Source",
        "ext": ["rb"],
        "mimeType": "text/x-ruby",
        "role": "Editor"
      },
      {
        "name": "C/C++ Source",
        "ext": ["c", "cpp", "cc", "h", "hpp"],
        "mimeType": "text/x-c++src",
        "role": "Editor"
      },
      {
        "name": "Java Source",
        "ext": ["java"],
        "mimeType": "text/x-java-source",
        "role": "Editor"
      },
      {
        "name": "PHP Source",
        "ext": ["php"],
        "mimeType": "text/x-php",
        "role": "Editor"
      },
      {
        "name": "Configuration",
        "ext": ["dockerfile", "gitignore", "editorconfig"],
        "mimeType": "text/plain",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "text-rs"
      },
      "wix": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
