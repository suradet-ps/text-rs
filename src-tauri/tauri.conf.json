{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "text-rs",
  "version": "0.2.0",
  "identifier": "com.textrs.texteditor",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "text-rs",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "center": true,
        "visible": true,
        "focus": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; img-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright 2026 text-rs",
    "category": "DeveloperTool",
    "shortDescription": "A fast, lightweight text editor",
    "longDescription": "text-rs is a cross-platform text editor built with Tauri, Svelte 5, and CodeMirror 6. Fast as Notepad, powerful for developers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Text Document",
        "ext": ["txt", "log", "csv", "tsv", "ini", "cfg", "conf", "env", "rst"],
        "role": "Editor",
        "rank": "Alternate",
        "contentTypes": ["public.plain-text", "public.text"]
      },
      {
        "name": "Markdown Document",
        "ext": ["md", "markdown", "mdown", "mkd"],
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "name": "Source Code",
        "ext": ["rs", "ts", "tsx", "js", "jsx", "mjs", "cjs", "py", "pyw", "go", "rb", "java", "c", "cpp", "cc", "h", "hpp", "php", "sh", "bash", "zsh", "fish"],
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "name": "HTML Document",
        "ext": ["html", "htm"],
        "role": "Editor",
        "rank": "Alternate",
        "contentTypes": ["public.html"]
      },
      {
        "name": "CSS Document",
        "ext": ["css", "scss", "less"],
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "name": "JSON Document",
        "ext": ["json", "jsonc"],
        "role": "Editor",
        "rank": "Alternate",
        "contentTypes": ["public.json"]
      },
      {
        "name": "XML Document",
        "ext": ["xml", "svg", "vue", "svelte"],
        "role": "Editor",
        "rank": "Alternate",
        "contentTypes": ["public.xml", "public.svg-image"]
      },
      {
        "name": "Config File",
        "ext": ["toml", "yaml", "yml", "sql", "graphql", "gql", "gitignore", "editorconfig", "dockerfile"],
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "./entitlements.plist",
      "infoPlist": "./custom-info.plist",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "text-rs"
      },
      "wix": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
